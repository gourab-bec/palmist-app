# ===== Palmly environment variables (set these in Vercel → Settings → Environment Variables) =====
# NEVER commit real values. NEVER expose anything except PUBLIC_BASE_URL to the browser.

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6            # optional override

# --- Supabase (service_role key — server only!) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...                  # service_role, NOT anon

# --- Sessions & OTP secrets (generate with: openssl rand -hex 32) ---
SESSION_SECRET=replace-with-64-hex-chars
OTP_SECRET=replace-with-a-different-64-hex-chars

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM=Palmly <palmist@getbriefed.to>   # domain must be verified in Resend
REPLY_TO=palmist@getbriefed.to               # forward this address to gourab.bec@gmail.com at your mail host

# --- SMS (Twilio) — required only if you offer phone sign-up ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM=+1XXXXXXXXXX                     # a Twilio number, or a Messaging Service SID (MG...)

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...                # use sk_test_... while testing
STRIPE_WEBHOOK_SECRET=whsec_...              # from the webhook endpoint you create
# Optional: pre-created Price IDs (otherwise inline prices of $2 / $3.99mo / $29.99yr are used)
STRIPE_PRICE_UNLOCK=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# --- App / security ---
PUBLIC_BASE_URL=https://palmist.getbriefed.to
ALLOWED_ORIGIN=https://palmist.getbriefed.to
CRON_SECRET=replace-with-64-hex-chars        # protects /api/daily-horoscope

# --- Admin allowlist (testing) ---
# Comma-separated emails/phones that bypass ALL payment requirements and the
# one-person-per-account binding. Phones must be E.164 (+countrycode).
# Set your REAL values only in Vercel env (do NOT commit them). Format example:
ADMIN_PRINCIPALS=email:you@example.com,phone:+1XXXXXXXXXX

# --- Legacy (optional) ---
ADMIN_PRO_TOKEN=
